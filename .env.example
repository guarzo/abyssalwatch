# Copy to .env and fill in your values. .env is gitignored.
# Loaded automatically in :dev via dotenvy (config/runtime.exs).
# After editing .env, restart `mix phx.server`.

# EVE Online SSO (https://developers.eveonline.com/)
EVE_CLIENT_ID=
EVE_CLIENT_SECRET=
EVE_CALLBACK_URL=http://localhost:4000/auth/eve/callback
